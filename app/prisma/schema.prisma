generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth ────────────────────────────────────────────────

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  emailVerified  DateTime?
  passwordHash   String
  mustChangePassword Boolean @default(true)
  name           String?
  role           Role      @default(CLINICIAN)
  clinicianType  String?
  credentials    String?
  npiNumber      String?
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  sessions       Session[]
  accounts       Account[]
  visits         Visit[]
  sharedVisits   VisitShareGrant[] @relation("VisitShareGrantee")
  grantsIssued   VisitShareGrant[] @relation("VisitShareGrantor")
  ownedTemplates NoteTemplate[] @relation("OwnedTemplates")
  subscriptions  Subscription[] @relation("UserSubscriptions")
  auditLogs      AuditLog[] @relation("AdminAuditLogs")
  styleProfile   ClinicianStyleProfile?
  styleFeedbackEvents ClinicianStyleFeedbackEvent[]
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  lastLoginAt    DateTime?
  isActive       Boolean   @default(true)
  mfaEnabled     Boolean   @default(false)
  mfaSecret      String?
  // Extended session HIPAA disclaimer
  extendedSessionAcknowledgedAt      DateTime?
  extendedSessionAcknowledgedVersion String?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}

// ─── Organization ────────────────────────────────────────

model Organization {
  id        String    @id @default(cuid())
  name      String
  npi       String?   @unique
  address   String?
  city      String?
  state     String?
  zip       String?
  phone     String?
  fax       String?
  users          User[]
  patients       Patient[]
  visits         Visit[]
  noteTemplates  NoteTemplate[]
  subscriptions  Subscription[] @relation("OrganizationSubscriptions")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model Subscription {
  id                     String             @id @default(cuid())
  planCode               PlanCode
  status                 SubscriptionStatus @default(trialing)
  billingInterval        BillingInterval    @default(monthly)
  provider               String?            // stripe, manual, sandbox
  externalCustomerId     String?
  externalSubscriptionId String?            @unique
  organizationId         String?
  organization           Organization?      @relation("OrganizationSubscriptions", fields: [organizationId], references: [id])
  userId                 String?
  user                   User?              @relation("UserSubscriptions", fields: [userId], references: [id])
  seatsIncluded          Int                @default(1)
  seatsUsed              Int                @default(1)
  quotaOverrides         Json?
  featureOverrides       Json?
  periodStart            DateTime?
  periodEnd              DateTime?
  cancelAtPeriodEnd      Boolean            @default(false)
  cancelledAt            DateTime?
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt

  usageEvents UsageLedger[]

  @@index([organizationId, status])
  @@index([userId, status])
  @@index([planCode, status])
}

model UsageLedger {
  id             String   @id @default(cuid())
  subscriptionId String?
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  userId         String?
  organizationId String?
  metric         String   // ai_calls, ai_tokens, notes_generated, audio_minutes
  quantity       Int      @default(0)
  metadata       Json?
  occurredAt     DateTime @default(now())

  @@index([subscriptionId, occurredAt])
  @@index([userId, occurredAt])
  @@index([organizationId, occurredAt])
  @@index([metric, occurredAt])
}

// ─── FHIR-Aligned Patient ────────────────────────────────

model Patient {
  id               String    @id @default(cuid())
  // FHIR: identifier — only required field
  identifier       String    // clinician-chosen ID (initials, MRN, internal ref)
  mrn              String?
  // FHIR: name
  firstName        String?
  lastName         String?
  middleName       String?
  prefix           String?   // Dr., Mr., Mrs.
  suffix           String?   // Jr., III
  // FHIR: birthDate, gender
  dateOfBirth      DateTime?
  gender           Gender?
  // FHIR: telecom
  phone            String?
  phoneSecondary   String?
  email            String?
  // FHIR: address
  addressLine1     String?
  addressLine2     String?
  city             String?
  state            String?
  zip              String?
  country          String?   @default("US")
  // FHIR: communication
  preferredLanguage String?  @default("en")
  // FHIR: maritalStatus
  maritalStatus    String?
  // FHIR: contact (emergency)
  emergencyContactName  String?
  emergencyContactPhone String?
  emergencyContactRelation String?
  // FHIR: generalPractitioner
  pcpName          String?
  pcpPhone         String?
  pcpFax           String?
  // Referring provider
  referringProvider String?
  referringProviderNpi String?
  // Organization
  organizationId   String?
  organization     Organization? @relation(fields: [organizationId], references: [id])
  // Relations
  visits           Visit[]
  coverages        Coverage[]
  allergies        Allergy[]
  medications      Medication[]
  conditions       Condition[]
  documents        PatientDocument[]
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([identifier])
  @@index([lastName, firstName])
  @@index([organizationId])
}

// FHIR: Coverage (insurance)
model Coverage {
  id             String   @id @default(cuid())
  patientId      String
  patient        Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  rank           Int      @default(1) // 1=primary, 2=secondary, 3=tertiary
  payerName      String
  memberId       String?
  groupNumber    String?
  planName       String?
  planType       String?  // HMO, PPO, Medicare, Medicaid, etc.
  copay          String?
  deductible     String?
  effectiveStart DateTime?
  effectiveEnd   DateTime?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([patientId])
}

// FHIR: AllergyIntolerance
model Allergy {
  id           String   @id @default(cuid())
  patientId    String
  patient      Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  substance    String
  reaction     String?
  severity     String?  // mild, moderate, severe
  status       String   @default("active") // active, inactive, resolved
  onsetDate    DateTime?
  createdAt    DateTime @default(now())

  @@index([patientId])
}

// FHIR: MedicationStatement
model Medication {
  id           String   @id @default(cuid())
  patientId    String
  patient      Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  name         String
  dose         String?
  frequency    String?
  route        String?
  prescriber   String?
  status       String   @default("active") // active, completed, stopped
  startDate    DateTime?
  endDate      DateTime?
  createdAt    DateTime @default(now())

  @@index([patientId])
}

// FHIR: Condition
model Condition {
  id           String   @id @default(cuid())
  patientId    String
  patient      Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  description  String
  icdCode      String?
  status       String   @default("active") // active, recurrence, relapse, inactive, remission, resolved
  onsetDate    DateTime?
  createdAt    DateTime @default(now())

  @@index([patientId])
}

// Scanned documents linked to patient
model PatientDocument {
  id           String   @id @default(cuid())
  patientId    String
  patient      Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  type         String   // drivers_license, insurance_front, insurance_back, intake_form, referral
  fileName     String
  mimeType     String
  extractedData Json?
  uploadedBy   String?
  createdAt    DateTime @default(now())

  @@index([patientId])
}

// ─── Note Templates ──────────────────────────────────────

model NoteTemplate {
  id                String         @id @default(cuid())
  name              String
  description       String?        @db.Text
  domain            String         // 'medical' | 'rehabilitation' | 'behavioral_health'
  noteFormat        String         // 'SOAP' | 'DAP' | 'narrative' | 'H&P' | 'eval' | 'custom'
  subtype           String?
  sourceType        String         // 'system' | 'user'
  sourceFrameworkId String?        // original frameworkId if cloned from built-in
  visibility        String         @default("private") // 'private' | 'organization'
  ownerUserId       String?
  ownerUser         User?          @relation("OwnedTemplates", fields: [ownerUserId], references: [id])
  organizationId    String?
  organization      Organization?  @relation(fields: [organizationId], references: [id])
  structureJson     Json           // validated by TemplateStructureSchema
  itemCount         Int
  version           Int            @default(1)
  isArchived        Boolean        @default(false)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  visits            Visit[]        @relation("TemplateVisits")
  styleFeedbackEvents ClinicianStyleFeedbackEvent[]

  @@index([ownerUserId])
  @@index([organizationId])
  @@index([domain])
  @@index([sourceType])
  @@index([visibility])
}

// ─── FHIR-Aligned Visit (Encounter) ─────────────────────

model Visit {
  id            String      @id @default(cuid())
  patientId     String
  patient       Patient     @relation(fields: [patientId], references: [id])
  userId        String
  user          User        @relation(fields: [userId], references: [id])
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  visibility     VisitVisibility @default(private)
  frameworkId           String
  domain                String
  templateId            String?
  template              NoteTemplate?  @relation("TemplateVisits", fields: [templateId], references: [id])
  templateSnapshotJson  Json?
  date          DateTime    @default(now())
  duration      Int?        // seconds
  status        VisitStatus @default(RECORDING)
  // Clinical data
  transcript    String?     @db.Text
  transcriptSource String?  // deepgram, mock
  transcriptConfidence Float?
  extractedFacts Json?
  clinicalSynthesis Json?
  parsedData    Json?
  noteData      Json?       // sections array
  auditResult   Json?
  cmsScore      Float?
  summary       String?
  generationTime Float?
  // Finalization & Amendments
  finalizedAt   DateTime?
  finalizedBy   String?
  amendments    Json?       // array of {id, timestamp, author, reason, changes}
  shareGrants   VisitShareGrant[]
  styleFeedbackEvents ClinicianStyleFeedbackEvent[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([userId])
  @@index([patientId])
  @@index([date])
  @@index([organizationId])
  @@index([organizationId, visibility])
}

model VisitShareGrant {
  id              String    @id @default(cuid())
  visitId         String
  visit           Visit      @relation(fields: [visitId], references: [id], onDelete: Cascade)
  granteeUserId   String
  granteeUser     User       @relation("VisitShareGrantee", fields: [granteeUserId], references: [id], onDelete: Cascade)
  grantedByUserId String
  grantedByUser   User       @relation("VisitShareGrantor", fields: [grantedByUserId], references: [id], onDelete: Cascade)
  permission      VisitSharePermission @default(view)
  createdAt       DateTime   @default(now())
  revokedAt       DateTime?

  @@index([visitId])
  @@index([granteeUserId])
  @@index([visitId, granteeUserId, revokedAt])
  @@unique([visitId, granteeUserId])
}

// ─── Audit ───────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  adminId    String?
  admin      User?    @relation("AdminAuditLogs", fields: [adminId], references: [id])
  userId     String? // legacy compatibility field
  action     String
  targetType String?
  targetId   String?
  metadata   Json?
  resource   String?
  details    Json?
  ip         String?
  ipAddress  String? // legacy compatibility field
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([adminId])
  @@index([createdAt])
  @@index([action])
  @@index([targetType, targetId])
  @@index([userId])
}

model ClinicianStyleProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  profileJson Json
  version     Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([updatedAt])
}

model ClinicianStyleFeedbackEvent {
  id            String                  @id @default(cuid())
  userId        String
  user          User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  visitId       String?
  visit         Visit?                  @relation(fields: [visitId], references: [id], onDelete: SetNull)
  templateId    String?
  template      NoteTemplate?           @relation(fields: [templateId], references: [id], onDelete: SetNull)
  eventType     ClinicianStyleEventType
  sectionKey    String?
  sectionTitle  String?
  snippetBefore String?
  snippetAfter  String?
  metadata      Json?
  createdAt     DateTime                @default(now())

  @@index([userId, createdAt])
  @@index([userId, eventType, createdAt])
  @@index([visitId])
  @@index([templateId])
}

// ─── Enums ───────────────────────────────────────────────

enum Role {
  ADMIN
  SUPER_ADMIN
  ENTERPRISE_ADMIN
  CLINICIAN
  SUPERVISOR
}

enum VisitStatus {
  RECORDING
  TRANSCRIBING
  GENERATING
  COMPLETE
  FINALIZED
  AMENDED
  ARCHIVED
}

enum Gender {
  MALE
  FEMALE
  OTHER
  UNKNOWN
}

enum VisitVisibility {
  private
  organization
  restricted
}

enum VisitSharePermission {
  view
  comment
}

enum PlanCode {
  starter
  professional
  practice
  enterprise
}

enum SubscriptionStatus {
  trialing
  active
  past_due
  canceled
  paused
}

enum BillingInterval {
  monthly
  annual
}

enum ClinicianStyleEventType {
  section_edit
  amendment
  regenerate_request
}
