import { NextRequest, NextResponse } from "next/server";
import { frameworks } from "@/lib/frameworks";
import { mockNotes } from "@/lib/mock-data";

async function callClaude(system: string, user: string, maxTokens: number = 4000) {
  const response = await fetch("https://api.anthropic.com/v1/messages", {
    method: "POST",
    headers: {
      "x-api-key": process.env.ANTHROPIC_API_KEY || "",
      "anthropic-version": "2023-06-01",
      "content-type": "application/json",
    },
    body: JSON.stringify({
      model: "claude-sonnet-4-20250514",
      max_tokens: maxTokens,
      temperature: 0,
      system,
      messages: [{ role: "user", content: user }],
    }),
  });

  if (!response.ok) {
    const errorText = await response.text();
    throw new Error(`Claude API error: ${errorText}`);
  }

  const result = await response.json();
  return {
    content: result.content?.[0]?.text || "",
    usage: result.usage,
  };
}

export async function POST(request: NextRequest) {
  const body = await request.json();
  const { transcript, frameworkId, useMock } = body;

  if (useMock === true || (!process.env.ANTHROPIC_API_KEY && !process.env.OPENAI_API_KEY)) {
    await new Promise((resolve) => setTimeout(resolve, 2000));
    let noteKey = "pt-eval";
    if (frameworkId === "med-soap-followup" || frameworkId === "med-soap-new" || frameworkId === "med-awv") {
      noteKey = "soap-followup";
    } else if (frameworkId?.startsWith("bh-")) {
      noteKey = "bh-intake";
    }
    const note = mockNotes[noteKey];
    return NextResponse.json({
      success: true,
      note: note || mockNotes["pt-eval"],
      summary: "Mock-generated clinical note.",
      generationTime: 2.0,
      sectionsGenerated: note?.length || 0,
      frameworkCoverage: 0.94,
      source: "mock",
    });
  }

  const framework = frameworks.find((f) => f.id === frameworkId);
  if (!framework) {
    return NextResponse.json({ success: false, error: "Framework not found" }, { status: 400 });
  }

  if (!transcript || transcript.trim().length === 0) {
    return NextResponse.json({ success: false, error: "No transcript provided" }, { status: 400 });
  }

  try {
    const startTime = Date.now();

    // ═══════════════════════════════════════════════════════════════
    // PASS 1: STRUCTURED FACT EXTRACTION WITH SOURCE TRACKING
    // ═══════════════════════════════════════════════════════════════
    
    // Build a dynamic JSON schema from the framework sections
    const schemaFields = framework.sections.map((s) => {
      const items = s.items.map((item) => {
        return `"${item.toLowerCase().replace(/[^a-z0-9]/g, '_')}": { "value": "string or null", "source": "transcript | not_documented | patient_denies" }`;
      });
      return `"${s.title.toLowerCase().replace(/[^a-z0-9]/g, '_')}": {\n      ${items.join(",\n      ")}\n    }`;
    });

    const extractSystem = `You are a clinical transcript fact extractor. You extract ONLY explicitly stated facts from a clinical encounter transcript into a structured JSON format.

ABSOLUTE RULES:
1. If a data element is explicitly stated in the transcript, set "value" to the stated information and "source" to "transcript".
2. If the patient or clinician explicitly denies or negates something, set "value" to the denial and "source" to "patient_denies".
3. If a data element is NOT mentioned anywhere in the transcript, set "value" to null and "source" to "not_documented".
4. NEVER fabricate, guess, infer, or assume ANY clinical data.
5. NEVER use your medical knowledge to fill in expected findings.
6. NEVER add information from medical training — only from the transcript.
7. An electrician is an electrician. A farmer is a farmer. Use the EXACT words from the transcript for demographics, occupation, and all factual data.
8. For measurements (ROM, vitals, scores): use ONLY exact numbers stated. If no number was stated, value is null.
9. For clinical findings: use ONLY findings explicitly described. If the clinician said "flexion is limited to 30 degrees" that is a fact. If the clinician did not mention extension, extension value is null.
10. If the clinician says "everything else is within normal limits" or "the rest is normal" for a specific assessment category, mark those items as value: "WNL" with source: "transcript".

Pay extremely careful attention to:
- Patient name (exact spelling from context)
- Age, gender, occupation (exact words used)
- All measurements and numbers (exact values)
- What was assessed vs what was not assessed

Return valid JSON matching the schema provided.`;

    const extractUser = `Extract clinical facts from this transcript into the following JSON schema. For every field: if the information was stated, include it with source "transcript". If not mentioned at all, set value to null and source to "not_documented". If explicitly denied, source is "patient_denies".

JSON SCHEMA:
{
  "patient_demographics": {
    "name": { "value": "string or null", "source": "transcript | not_documented" },
    "age": { "value": "string or null", "source": "transcript | not_documented" },
    "gender": { "value": "string or null", "source": "transcript | not_documented" },
    "occupation": { "value": "string or null", "source": "transcript | not_documented" },
    "handedness": { "value": "string or null", "source": "transcript | not_documented" }
  },
  ${schemaFields.join(",\n  ")},
  "additional_facts": [
    { "fact": "string", "quote": "approximate quote from transcript", "source": "transcript" }
  ]
}

TRANSCRIPT:
---
${transcript}
---

Remember: null and "not_documented" for ANYTHING not explicitly stated. Do not fill in blanks with medical knowledge.`;

    const extractResult = await callClaude(extractSystem, extractUser, 4000);
    const structuredFacts = extractResult.content;

    // ═══════════════════════════════════════════════════════════════
    // PASS 2: GENERATE NOTE STRICTLY FROM STRUCTURED FACTS JSON
    // ═══════════════════════════════════════════════════════════════

    const sectionPrompt = framework.sections
      .map((s) => {
        const items = s.items.join(", ");
        return `### ${s.title}\nItems: ${items}`;
      })
      .join("\n\n");

    const noteSystem = `You are a clinical note renderer. You convert structured JSON clinical data into a formatted clinical note.

CRITICAL RULES:
1. You are generating a clinical note STRICTLY from the provided JSON facts. The JSON is your ONLY data source.
2. You MUST NOT add any new clinical details not present in the JSON.
3. For any field where "source" is "not_documented" or value is null:
   - Include the item label followed by "___" (blank for clinician to fill)
   - Example: "Occupation: ___"
   - Example: "Lumbar Extension ROM: ___"
4. For any field where "source" is "transcript" and value is not null:
   - Document the value using proper clinical language
5. For any field where "source" is "patient_denies":
   - Document as "Patient denies [item]" or appropriate clinical phrasing
6. For fields with value "WNL" and source "transcript":
   - Document as "WNL" or "Within normal limits"
7. Do NOT infer diagnoses, severity, prognosis, or treatments not in the JSON.
8. Do NOT add standard clinical phrases like "alert and oriented" unless it's in the JSON.
9. Do NOT add review of systems findings not in the JSON.
10. A note with many "___" blanks is CORRECT when the transcript was brief.
11. Use third-person clinical voice.
12. For tables (ROM, MMT): show actual values from JSON, WNL where indicated, ___ where not_documented.

FRAMEWORK: ${framework.name}
TYPE: ${framework.type} — ${framework.subtype}

STRUCTURE:
${sectionPrompt}

OUTPUT: Return ONLY a JSON array: [{ "title": "section title", "content": "formatted section content with markdown" }]
Do not include any text outside the JSON array.`;

    const noteUser = `STRUCTURED CLINICAL FACTS (your ONLY data source — if source is "not_documented" or value is null, that item MUST be "___" in the note):

${structuredFacts}

Generate the ${framework.name} clinical note. Every item with null value or "not_documented" source MUST appear as "Label: ___" in the note. Do not skip them and do not fill them in.`;

    const noteResult = await callClaude(noteSystem, noteUser, 4000);
    const generationTime = (Date.now() - startTime) / 1000;

    // Parse the note
    let note;
    try {
      const raw = noteResult.content.trim();
      const jsonMatch = raw.match(/\[[\s\S]*\]/);
      if (jsonMatch) {
        note = JSON.parse(jsonMatch[0]);
      } else {
        const parsed = JSON.parse(raw);
        note = Array.isArray(parsed) ? parsed : parsed.sections || parsed.note || [parsed];
      }
    } catch {
      note = [{ title: "Clinical Note", content: noteResult.content }];
    }

    // ═══════════════════════════════════════════════════════════════
    // PASS 3: BRIEF SUMMARY (only from documented findings)
    // ═══════════════════════════════════════════════════════════════
    let summary = "Clinical note generated from encounter transcript.";
    try {
      const summaryResult = await callClaude(
        "Write a 2-3 sentence visit summary. Only reference facts that were documented (not items marked as ___). Be concise and clinical.",
        JSON.stringify(note),
        200
      );
      summary = summaryResult.content || summary;
    } catch {
      // non-critical
    }

    return NextResponse.json({
      success: true,
      note,
      summary,
      extractedFacts: structuredFacts,
      generationTime: Math.round(generationTime * 10) / 10,
      sectionsGenerated: note.length,
      source: "claude-sonnet",
      tokensUsed:
        (extractResult.usage?.input_tokens || 0) +
        (extractResult.usage?.output_tokens || 0) +
        (noteResult.usage?.input_tokens || 0) +
        (noteResult.usage?.output_tokens || 0),
    });
  } catch (error) {
    console.error("Note generation error:", error);
    return NextResponse.json(
      { success: false, error: "Note generation service error", details: String(error) },
      { status: 500 }
    );
  }
}
