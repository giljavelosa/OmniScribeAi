{
  "name": "app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:local": "NODE_OPTIONS=--max-old-space-size=6144 next dev",
    "typecheck": "tsc --noEmit",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "db:reset": "prisma db push --force-reset && npm run db:seed",
    "test": "vitest run -c vitest.critical.config.ts",
    "test:full": "vitest run",
    "test:watch": "vitest",
    "test:critical": "vitest run -c vitest.critical.config.ts",
    "test:contracts": "vitest run -c vitest.critical.config.ts ./tests/contracts/api-contract.test.ts ./tests/contracts/core-route-contracts.test.ts",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "PWDEBUG=1 playwright test --headed",
    "test:e2e:ci": "playwright test --retries=1",
    "test:runtime": "npm run test:contracts && npm run test:e2e:ci",
    "quality:gate": "npm run build && npm run test:critical && npm run test:full",
    "test:integration": "npm run test:integration:setup && npm run test:full && npm run test:integration:teardown",
    "test:integration:setup": "docker compose -f ../docker-compose.yml up -d --wait && npm run db:push && npm run db:seed",
    "test:integration:wait": "tsx scripts/wait-for-db.ts",
    "test:integration:teardown": "docker compose -f ../docker-compose.yml down",
    "test:notes": "tsx scripts/run-note-tests.ts",
    "test:notes:mock": "tsx scripts/run-note-tests.ts --mock",
    "test:audio:generate": "tsx scripts/generate-test-audio.ts",
    "test:notes:audio": "tsx scripts/run-audio-tests.ts",
    "test:notes:audio:transcribe": "tsx scripts/run-audio-tests.ts --transcribe-only",
    "test:audio:generate:long": "tsx scripts/generate-test-audio.ts --long",
    "test:notes:audio:long": "tsx scripts/run-audio-tests.ts --long",
    "deploy:staging:preflight": "bash scripts/deploy-staging-preflight.sh",
    "dev:ensure": "bash scripts/ensure-local-dev.sh",
    "test:critical:with-dev": "npm run test:critical; npm run dev:ensure",
    "test:full:with-dev": "npm run test:full; npm run dev:ensure",
    "verify:fast": "bash scripts/verify-fast.sh",
    "verify:gate": "bash scripts/verify-gate.sh",
    "server:test:start": "bash scripts/start-test-server.sh",
    "server:test:stop": "bash scripts/stop-test-server.sh",
    "smoke:auth": "bash scripts/smoke-auth.sh",
    "hooks:install": "bash scripts/install-git-hooks.sh",
    "prepare": "npm run hooks:install"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@prisma/client": "^6.19.2",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/themes": "^3.3.0",
    "bcryptjs": "^3.0.3",
    "next": "16.1.6",
    "next-auth": "^5.0.0-beta.30",
    "pg": "^8.18.0",
    "prisma": "^6.19.2",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "stripe": "^17.7.0",
    "tsx": "^4.21.0",
    "zod": "^4.3.6"
  },
  "overrides": {
    "minimatch": "^10.2.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/pg": "^8.16.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.3.1",
    "eslint": "^9.39.3",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}
