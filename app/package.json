{
  "name": "app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "db:reset": "prisma db push --force-reset && npm run db:seed",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "npm run test:integration:setup && npm run test && npm run test:integration:teardown",
    "test:integration:setup": "docker compose -f ../docker-compose.yml up -d --wait && npm run db:push && npm run db:seed",
    "test:integration:wait": "tsx scripts/wait-for-db.ts",
    "test:integration:teardown": "docker compose -f ../docker-compose.yml down",
    "test:notes": "tsx scripts/run-note-tests.ts",
    "test:notes:mock": "tsx scripts/run-note-tests.ts --mock"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@prisma/client": "^6.19.2",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/themes": "^3.3.0",
    "bcryptjs": "^3.0.3",
    "next": "16.1.6",
    "next-auth": "^5.0.0-beta.30",
    "pg": "^8.18.0",
    "prisma": "^6.19.2",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "tsx": "^4.21.0"
  },
  "overrides": {
    "minimatch": "^10.2.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/pg": "^8.16.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.3.1",
    "eslint": "^9.39.3",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}
